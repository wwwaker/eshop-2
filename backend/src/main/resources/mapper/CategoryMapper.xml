<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.eshop.dao.CategoryDao">
    <resultMap id="BaseResultMap" type="com.example.eshop.entity.Category">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createdAt" column="created_at"/>
    </resultMap>

    <select id="findAll" resultMap="BaseResultMap">
        SELECT * FROM categories ORDER BY sort_order
    </select>
    <select id="findAllWithFilters" resultMap="BaseResultMap" parameterType="map">
        SELECT * FROM categories
        WHERE 1=1
        <if test="search != null and search != ''">
            AND name LIKE CONCAT('%', #{search}, '%')
        </if>
        <if test="sortField != null and sortField != ''">
            ORDER BY ${sortField}
            <if test="sortOrder != null and sortOrder != ''">
                ${sortOrder}
            </if>
        </if>
        <if test="sortField == null or sortField == ''">
            ORDER BY sort_order
        </if>
    </select>
    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM categories WHERE id = #{id}
    </select>
    
    <!-- 管理员系统方法 -->
    <insert id="insert" parameterType="com.example.eshop.entity.Category" 
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO categories (name, description, sort_order) 
        VALUES (#{name}, #{description}, #{sortOrder})
    </insert>
    <update id="update" parameterType="com.example.eshop.entity.Category">
        UPDATE categories 
        SET name = #{name}, 
            description = #{description}, 
            sort_order = #{sortOrder} 
        WHERE id = #{id}
    </update>
    <delete id="deleteById">
        DELETE FROM categories WHERE id = #{id}
    </delete>
</mapper>
