<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.eshop.dao.SysLogDao">
    <resultMap id="sysLogResultMap" type="com.example.eshop.entity.SysLog">
        <id property="id" column="id"/>
        <result property="logLevel" column="log_level"/>
        <result property="logContent" column="log_content"/>
        <result property="createTime" column="create_time"/>
        <result property="className" column="class_name"/>
        <result property="methodName" column="method_name"/>
        <result property="requestUrl" column="request_url"/>
        <result property="username" column="username"/>
        <result property="ip" column="ip"/>
    </resultMap>

    <insert id="insert" parameterType="com.example.eshop.entity.SysLog">
        INSERT INTO sys_logs (
            log_level, log_content, create_time, class_name, method_name, request_url, username, ip
        ) VALUES (
            #{logLevel}, #{logContent}, #{createTime}, #{className}, #{methodName}, #{requestUrl}, #{username}, #{ip}
        )
    </insert>

    <select id="findAll" resultMap="sysLogResultMap">
        SELECT * FROM sys_logs ORDER BY create_time DESC
    </select>

    <select id="findByUsername" resultMap="sysLogResultMap">
        SELECT * FROM sys_logs WHERE username = #{username} ORDER BY create_time DESC
    </select>
</mapper>